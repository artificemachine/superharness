# JSONL event stream — runtime data, not source
.superharness/events.jsonl
.hablatone-project
.ship-check-passed
# ShipGuard runtime state — written relative to the scan cwd, so it appears in
# any subdirectory that has been scanned, not just the repo root.
.shipguard/

.env
*.key
*.pem
*.p12
*.pfx
# Session working docs — handoffs, audits, plans, reports
docs/HANDOFF-*.md
docs/AUDIT-*.md
docs/PLAN-*.md
docs/bulletproof-report-*.md
# Portfolio-ready audit artifacts (command renamed from job-ready 2026-07-21)
# — working docs, not repo content. Kept local so a findings report cannot
# re-leak the PII it documents into a tracked file (see the 2026-07-21 audit
# report that tripped test_no_tracked_personal_data).
docs/audits/*job-ready*
docs/audits/job-ready-*
docs/audits/*portfolio-ready*
docs/audits/portfolio-ready-*
docs/audits/branch-recovery-*
# Evidence backing the ignored audits above (agent transcripts, captured state)
docs/discussions/
